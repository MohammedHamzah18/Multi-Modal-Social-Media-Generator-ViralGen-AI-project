# VoiceOps Sentinel Backend Configuration
APP_NAME=VoiceOps Sentinel
DEBUG=false
SECRET_KEY=generate-with-openssl-rand-hex-32

# LOCAL DEV (no PostgreSQL needed) — use this on Windows:
DATABASE_URL=sqlite+aiosqlite:///./data/voiceops.db

# DOCKER / PRODUCTION — PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://voiceops:voiceops@localhost:5432/voiceops_sentinel

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI (optional — demo mode works without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

HUGGINGFACE_TOKEN=
ENABLE_PYANNOTE=false

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=100
PRESIDIO_ENABLED=false
LOG_LEVEL=INFO
